APP_NAME=律镜 Legal Copilot
DATABASE_URL=
TOP_K=5
EMBEDDING_DIMENSIONS=384
OFFLINE_MODE=true
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=60
EMBEDDING_PROVIDER=hash
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=text-embedding-3-small
RETRIEVAL_KEYWORD_WEIGHT=0.35
RETRIEVAL_SEMANTIC_WEIGHT=0.65
MAX_WORKFLOW_RETRIES=2
MAX_UPLOAD_BYTES=10485760
DOCUMENT_PARSE_TIMEOUT_SECONDS=15
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:3000,http://localhost:3000

# 兼容旧项目的变量名。若使用这些名称，可不再重复填写上面的 LLM_*：
# OPENAI_API_KEY=your_rotated_api_key
# OPENAI_BASE_URL=https://api.deepseek.com
# MODEL_NAME=deepseek-v4-flash

# MySQL、Redis、RocketMQ 当前未接入本项目，请勿把生产密码写入此文件或提交到 Git。
